{
  "name": "angular2-clockmaker-labs",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npm run tsc:w\" \"npm run lite\" ",
    "tsc": "tsc -p ./",
    "lite": "lite-server",
    "typings": "typings",
    "postinstall": "typings install",
    "browserify": "browserify ./app/boot.js -t babelify -o ./_labs/bundle.js",
    "build": "npm run tsc && npm run browserify"
  },
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "license": "ISC",
  "dependencies": {
    "angular2": "^2.0.0-beta.13",
    "babel-preset-es2015": "^6.6.0",
    "systemjs": "0.19.24",
    "es6-promise": "^3.1.2",
    "es6-shim": "0.35.0",
    "reflect-metadata": "0.1.2",
    "rxjs": "5.0.0-beta.2",
    "zone.js": "0.6.6"
  },
  "devDependencies": {
    "babelify": "^7.2.0",
    "browserify": "^13.0.0",
    "concurrently": "^2.0.0",
    "lite-server": "^2.1.0",
    "typescript": "^1.8.9",
    "typings": "^0.7.5"
  }
}